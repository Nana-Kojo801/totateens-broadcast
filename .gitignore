# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Env files (secrets) — .env.production is the exception: it only holds
# non-sensitive, build-required values (Convex's public client URL, the
# fixed localhost sidecar port) that every build needs, including CI, so
# it's committed rather than gitignored.
.env
.env.*
!.env.production

# WhatsApp session — never commit real credentials
.wwebjs_auth
.wwebjs_cache

# Tauri sidecar build output
src-tauri/binaries

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
