{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "TOTATeens Broadcast",
  "version": "0.1.0",
  "identifier": "org.trumpetsoftheages.totateens-broadcast",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev:client",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "TOTATeens Broadcast",
        "width": 1280,
        "height": 800,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#F7F7F4"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/totateens-wa-server"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdDRjREOENDQ0Q4M0EyQjUKUldTMW9vUE56TmowZlBCRTZOaTlEZ3Y2c3hMd04wL3gyYmVpT0hNMC81WkpiM3pVYnh1YVZ5ZEcK",
      "endpoints": [
        "https://github.com/Nana-Kojo801/totateens-broadcast/releases/latest/download/latest.json"
      ]
    }
  }
}
